    {
      "id": "storyboard-template",
      "name": "视频分镜模板速填",
      "description": "用影视分镜语言快速生成 AI 视频提示词，中英对照",
      "icon": "Film",
      "tags": ["分镜", "视频", "Runway"],
      "toolboxCategory": "creation",
      "scenario": "video",
      "type": "template-fill",
      "guide": "选项均为中英对照，预览区上方中文帮助理解，下方英文可直接复制到 Runway / Pika。",
      "template": "A {shot_type} of {subject} in {location}, {mood} atmosphere, {lighting} lighting, camera movement: {movement}, shot on {lens}, cinematic color grading, --ar {aspect}",
      "templateZh": "一段{shot_type}，主体为{subject}，场景在{location}，{mood}氛围，{lighting}光线，镜头运动：{movement}，使用{lens}拍摄，电影级调色，画幅比 {aspect}",
      "placeholders": [
        {
          "key": "shot_type",
          "label": "景别",
          "type": "select",
          "options": [
            { "en": "wide establishing shot", "zh": "大远景建立镜头" },
            { "en": "medium shot", "zh": "中景" },
            { "en": "close-up", "zh": "特写" },
            { "en": "extreme close-up", "zh": "大特写" },
            { "en": "over-the-shoulder shot", "zh": "过肩镜头" }
          ],
          "default": "wide establishing shot"
        },
        {
          "key": "subject",
          "label": "主体",
          "type": "text",
          "default": "a lone traveler",
          "defaultZh": "孤独的旅人",
          "placeholderZh": "孤独的旅人"
        },
        {
          "key": "location",
          "label": "场景",
          "type": "text",
          "default": "a rain-soaked Tokyo alley at night",
          "defaultZh": "雨夜东京小巷",
          "placeholderZh": "雨夜东京小巷"
        },
        {
          "key": "mood",
          "label": "情绪",
          "type": "select",
          "options": [
            { "en": "melancholic", "zh": "忧郁" },
            { "en": "tense", "zh": "紧张" },
            { "en": "dreamy", "zh": "梦幻" },
            { "en": "epic", "zh": "史诗" },
            { "en": "intimate", "zh": "亲密" }
          ],
          "default": "melancholic"
        },
        {
          "key": "lighting",
          "label": "光线",
          "type": "select",
          "options": [
            { "en": "neon reflections", "zh": "霓虹反射" },
            { "en": "soft golden hour", "zh": "柔和黄金时刻" },
            { "en": "harsh fluorescent", "zh": "刺眼荧光灯" },
            { "en": "candlelit", "zh": "烛光" },
            { "en": "moonlight", "zh": "月光" }
          ],
          "default": "neon reflections"
        },
        {
          "key": "movement",
          "label": "镜头运动",
          "type": "select",
          "options": [
            { "en": "slow dolly in", "zh": "缓慢推镜" },
            { "en": "tracking shot", "zh": "跟拍" },
            { "en": "static", "zh": "固定机位" },
            { "en": "crane up", "zh": "摇臂上升" },
            { "en": "handheld", "zh": "手持拍摄" }
