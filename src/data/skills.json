    {
      "id": "video-duration-calc",
      "name": "AI 视频时长/帧率换算器",
      "description": "秒数、帧率、总帧数一键互算，规划分镜节奏",
      "icon": "Calculator",
      "tags": ["换算", "帧率", "分镜"],
      "toolboxCategory": "utility",
      "scenario": "production",
      "type": "calculator",
      "guide": "输入任意两项即可推算第三项，适合规划 AI 视频片段长度与导出设置。",
      "calculator": {
        "formula": "duration-frames",
        "description": "视频时长 = 总帧数 ÷ 帧率。修改任意字段，其余自动计算。",
        "fields": [
          { "key": "duration", "label": "时长（秒）", "type": "number", "unit": "s", "default": 5 },
          { "key": "fps", "label": "帧率", "type": "select", "options": ["24", "25", "30", "60"], "default": "24" },
          { "key": "frames", "label": "总帧数", "type": "number", "unit": "frames", "default": 120 }
        ]
      }
