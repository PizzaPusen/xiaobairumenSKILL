        {
          "key": "lens",
          "label": "焦段",
          "type": "select",
          "options": [
            { "en": "35mm anamorphic", "zh": "35mm 变形宽银幕" },
            { "en": "50mm", "zh": "50mm 标准" },
            { "en": "85mm", "zh": "85mm 人像" },
            { "en": "24mm wide", "zh": "24mm 广角" }
